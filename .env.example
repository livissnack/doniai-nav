# Vue 3 + Vite 环境变量（开发建议在 WSL 中运行 npm run dev）
VITE_WEB_PORT=1343
VITE_PREVIEW_PORT=4173
VITE_SERVER_URL=/api/
# 开发：本地后端；预览/生产构建：见 .env.production
VITE_API_PROXY_TARGET=http://127.0.0.1:3001
# WSL 局域网开发：填浏览器地址栏 IP，修复 HMR WebSocket（如 172.23.76.210）
# VITE_HMR_HOST=172.23.76.210
# 若仍连不上 WebSocket，可临时关闭热更新（页面可正常用）：
# VITE_HMR_DISABLE=1
# 文件监听异常时可开启轮询（配置 VITE_HMR_HOST 时会自动开启）
# VITE_USE_POLLING=1
# 与后端 AUTH_TOKEN 一致（/all、/hotel、/convert、/refresh 需要）
VITE_SECRET_KEY=your-service-bearer-token
# VITE_OSS_CDN=
# VITE_SSE_URL=